{
  "compilerOptions": {

    "target": "ES2020",

    "module": "NodeNext",

    "isolatedModules": true,

    "moduleResolution": "NodeNext",

    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types": [
      "node",
      "jest"
    ]

  },

  "include": [
    "src"
  ]
}